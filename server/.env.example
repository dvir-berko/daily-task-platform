# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost

# JWT / Sessions
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=another-long-random-string

# Google OAuth 2.0
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin override (first registered user becomes admin automatically)
# ADMIN_EMAIL=you@example.com

# Twilio WhatsApp (optional — https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# Email Reminders via SMTP (optional)
# Works with Gmail App Passwords, SendGrid SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Legacy (no longer used)
# REMINDER_TIME=08:00
# REMINDER_TIMEZONE=Asia/Jerusalem